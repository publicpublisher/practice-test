        "---\n",
        "## 6. 멀티헤드 어텐션 완전 구현 (넘파이만 사용)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "title": "============================================================"
      },
      "outputs": [],
      "source": [
        "# ============================================================\n",
        "# Multi-Head Attention 완전 구현 (NumPy만 사용)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "title": "Cell 26"
      },
      "outputs": [],
      "source": [
        "class MultiHeadAttention:\n",
        "    \"\"\"\n",
        "    Multi-Head Attention 구현\n",
        "    \n",
        "    논문: 'Attention Is All You Need' (Vaswani et al., 2017)\n",
        "    \n",
        "    동작 원리:\n",
        "    1. 입력 X를 Q, K, V로 선형 변환\n",
        "    2. num_heads개로 나눠서 각각 Attention 계산\n",
        "    3. 결과를 합쳐서 출력 선형 변환\n",
        "    \"\"\"\n",
        "    \n",
        "    def __init__(self, d_model, num_heads, seed=42):\n",
        "        \"\"\"\n",
        "        Args:\n",
        "            d_model: 모델 임베딩 차원 (예: 512)\n",
        "            num_heads: 어텐션 헤드 수 (예: 8)\n",
        "        \"\"\"\n",
        "        assert d_model % num_heads == 0, (\n",
        "            f'd_model({d_model})은 num_heads({num_heads})로 나누어져야 합니다!'\n",
        "        )\n",
        "        np.random.seed(seed)\n",
        "        \n",
        "        self.d_model = d_model\n",
        "        self.num_heads = num_heads\n",
        "        self.d_k = d_model // num_heads  # 각 헤드의 차원\n",
        "        \n",
        "        # Xavier 초기화 (가중치가 너무 크거나 작지 않도록)\n",
        "        scale = np.sqrt(2.0 / (d_model + d_model))\n",
        "        self.W_Q = np.random.randn(d_model, d_model) * scale\n",
        "        self.W_K = np.random.randn(d_model, d_model) * scale\n",
        "        self.W_V = np.random.randn(d_model, d_model) * scale\n",
        "        self.W_O = np.random.randn(d_model, d_model) * scale  # 출력 투영 행렬\n",
        "    \n",
        "    def split_heads(self, x):\n",
        "        \"\"\"\n",
        "        텐서를 num_heads개로 분할\n",
        "        (batch, seq, d_model) → (batch, num_heads, seq, d_k)\n",
        "        \"\"\"\n",
        "        batch, seq, _ = x.shape\n",
        "        # reshape: 마지막 차원을 (num_heads, d_k)로\n",
        "        x = x.reshape(batch, seq, self.num_heads, self.d_k)\n",
        "        # transpose: (batch, seq, heads, d_k) → (batch, heads, seq, d_k)\n",
        "        return x.transpose(0, 2, 1, 3)\n",
        "    \n",
        "    def merge_heads(self, x):\n",
        "        \"\"\"\n",
        "        분할된 텐서를 다시 합치기\n",
        "        (batch, num_heads, seq, d_k) → (batch, seq, d_model)\n",
        "        \"\"\"\n",
        "        batch, _, seq, _ = x.shape\n",
        "        # (batch, heads, seq, d_k) → (batch, seq, heads, d_k)\n",
        "        x = x.transpose(0, 2, 1, 3)\n",
        "        # (batch, seq, heads*d_k) = (batch, seq, d_model)\n",
        "        return x.reshape(batch, seq, self.d_model)\n",
        "    \n",
        "    @staticmethod\n",
        "    def softmax(x):\n",
        "        \"\"\"수치 안정적인 softmax (최대값 빼기)\"\"\"\n",
        "        e_x = np.exp(x - x.max(axis=-1, keepdims=True))\n",
        "        return e_x / e_x.sum(axis=-1, keepdims=True)\n",
        "    \n",
        "    def forward(self, X, mask=None):\n",
        "        \"\"\"\n",
        "        순전파\n",
        "        \n",
        "        Args:\n",
        "            X: 입력 텐서 (batch, seq, d_model)\n",
        "            mask: 마스크 행렬 (선택사항) - 패딩이나 미래 토큰 가리기\n",
        "        Returns:\n",
        "            output: (batch, seq, d_model)\n",
        "            attention_weights: (batch, num_heads, seq, seq)\n",
        "        \"\"\"\n",
        "        batch, seq, _ = X.shape\n",
        "        \n",
        "        # Step 1: Q, K, V 계산\n",
        "        Q = X @ self.W_Q  # (batch, seq, d_model)\n",
        "        K = X @ self.W_K\n",
        "        V = X @ self.W_V\n",
        "        \n",
        "        # Step 2: 헤드 분할\n",
        "        Q = self.split_heads(Q)  # (batch, heads, seq, d_k)\n",
        "        K = self.split_heads(K)\n",
        "        V = self.split_heads(V)\n",
        "        \n",
        "        # Step 3: Scaled Dot-Product Attention\n",
        "        # (batch, heads, seq, d_k) @ (batch, heads, d_k, seq) = (batch, heads, seq, seq)\n",
        "        scores = Q @ K.transpose(0, 1, 3, 2) / np.sqrt(self.d_k)\n",
        "        \n",
        "        # 마스크 적용 (선택사항)\n",
        "        if mask is not None:\n",
        "            scores = np.where(mask == 0, -1e9, scores)\n",
        "        \n",
        "        attention_weights = self.softmax(scores)  # (batch, heads, seq, seq)\n",
        "        \n",
        "        # Step 4: 가중합\n",
        "        context = attention_weights @ V  # (batch, heads, seq, d_k)\n",
        "        \n",
        "        # Step 5: 헤드 합치기\n",
        "        context = self.merge_heads(context)  # (batch, seq, d_model)\n",
        "        \n",
        "        # Step 6: 출력 투영\n",
        "        output = context @ self.W_O  # (batch, seq, d_model)\n",
        "        \n",
        "        return output, attention_weights\n",
        "\n",
        "\n",
        "# 테스트\n",
        "d_model = 16\n",
        "num_heads = 4\n",
        "batch_size = 2\n",
        "seq_len = 6\n",
        "\n",
        "mha = MultiHeadAttention(d_model=d_model, num_heads=num_heads)\n",
        "X = np.random.randn(batch_size, seq_len, d_model)\n",
        "\n",
        "output, attn = mha.forward(X)\n",
        "\n",
        "print('=== Multi-Head Attention 테스트 ===')\n",
        "print(f'입력 X: {X.shape}')\n",
        "print(f'출력: {output.shape}  (입력과 동일!)')\n",
        "print(f'어텐션 가중치: {attn.shape}  (batch, heads, seq, seq)')\n",
        "print()\n",
        "print(f'각 헤드 차원 d_k: {mha.d_k}')\n",
        "print(f'파라미터 수: {4 * d_model * d_model:,} (W_Q + W_K + W_V + W_O)')\n",
        "print()\n",
        "\n",
        "# 어텐션 가중치 확인 (각 행의 합 = 1)\n",
        "row_sums = attn.sum(axis=-1)\n",
        "print(f'어텐션 가중치 행합 (모두 1이어야 함):')\n",
        "print(row_sums[0, 0, :])  # 첫번째 배치, 첫번째 헤드의 각 행 합"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
