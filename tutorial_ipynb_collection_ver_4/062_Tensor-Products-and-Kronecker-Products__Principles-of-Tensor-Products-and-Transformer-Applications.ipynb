        "# 연습 문제 2: Causal Mask (GPT 스타일 디코더)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "title": "Cell 33"
      },
      "outputs": [],
      "source": [
        "print('연습 문제 2: Causal Mask (인과 마스크) 만들기')\n",
        "print('GPT는 미래 토큰을 볼 수 없게 하는 마스크를 사용합니다.')\n",
        "print('5x5 하삼각 마스크를 만들어보세요.')\n",
        "print()\n",
        "\n",
        "seq_len = 5\n",
        "# np.tril: 하삼각행렬 (대각선 포함 아래쪽만 1)\n",
        "causal_mask = np.tril(np.ones((seq_len, seq_len)))\n",
        "print('Causal Mask (1=볼 수 있음, 0=볼 수 없음):')\n",
        "print(causal_mask.astype(int))\n",
        "print()\n",
        "print('→ (i,j)=0이면 i번 토큰이 j번 토큰(미래)을 볼 수 없음!')\n",
        "print('  Attention Score에서 해당 위치를 -∞로 만들면 softmax 후 0이 됩니다.')\n",
        "\n",
        "# 마스크 적용 예시\n",
        "dummy_scores = np.random.randn(seq_len, seq_len)\n",
        "masked_scores = np.where(causal_mask == 0, -1e9, dummy_scores)\n",
        "\n",
        "def softmax_2d(x):\n",
        "    e_x = np.exp(x - x.max(axis=-1, keepdims=True))\n",
        "    return e_x / e_x.sum(axis=-1, keepdims=True)\n",
        "\n",
        "masked_attention = softmax_2d(masked_scores)\n",
        "print(f'\\n마스크 적용 후 Attention 가중치 (상삼각은 모두 0!):')\n",
        "print(masked_attention.round(3))"
      ]
    },
