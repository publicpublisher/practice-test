      "source": [
        "# ============================================================\n",
        "# 연습 문제 1: 크로네커 곱과 표준 행렬 곱의 관계"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "title": "Cell 31"
      },
      "outputs": [],
      "source": [
        "print('연습 문제 1:')\n",
        "print('vec(AXB) = (Bᵀ ⊗ A) vec(X) 임을 확인하세요')\n",
        "print('(vec: 행렬을 열벡터로 펼치는 연산, numpy에서는 .flatten(order=\"F\"))')\n",
        "print()\n",
        "\n",
        "np.random.seed(1)\n",
        "A_q = np.random.randn(3, 3)\n",
        "X_q = np.random.randn(3, 3)  \n",
        "B_q = np.random.randn(3, 3)\n",
        "\n",
        "# 좌변: AXB를 column-major로 flatten\n",
        "lhs = (A_q @ X_q @ B_q).flatten(order='F')  # 열 우선(Fortran order) flatten\n",
        "\n",
        "# 우변: (Bᵀ ⊗ A) vec(X)\n",
        "kron_BtA = np.kron(B_q.T, A_q)  # (9x9)\n",
        "vec_X = X_q.flatten(order='F')   # (9,)\n",
        "rhs = kron_BtA @ vec_X\n",
        "\n",
        "print(f'좌변 vec(AXB) = {lhs[:5]}...')\n",
        "print(f'우변 (Bᵀ⊗A)vec(X) = {rhs[:5]}...')\n",
        "print(f'등식 성립? {np.allclose(lhs, rhs)}')\n",
        "\n",
        "print()"
      ]
    },
