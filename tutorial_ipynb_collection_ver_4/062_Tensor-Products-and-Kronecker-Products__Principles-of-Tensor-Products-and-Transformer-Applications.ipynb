        "# 예: 2개 문장, 각 문장 4개 토큰, 토큰당 8차원 임베딩\n",
        "batch_tensor = np.random.randn(2, 4, 8)\n",
        "print(f'\\n3D 텐서 (batch=2, seq=4, d=8):')\n",
        "print(f'shape={batch_tensor.shape}, 전체 원소 수={batch_tensor.size}')\n",
