      "source": [
        "# ============================================================\n",
        "# 텐서 reshape와 permute: Multi-Head Attention의 핵심"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "title": "Cell 20"
      },
      "outputs": [],
      "source": [
        "print('=== Multi-Head Attention의 텐서 변환 과정 ===')\n",
        "print()\n",
        "\n",
        "batch_size = 2\n",
        "seq_len = 5\n",
        "d_model = 16  # 전체 임베딩 차원\n",
        "num_heads = 4  # 어텐션 헤드 수\n",
        "d_k = d_model // num_heads  # 각 헤드의 차원 = 16//4 = 4\n",
        "\n",
        "print(f'설정: batch={batch_size}, seq={seq_len}, d_model={d_model}')\n",
        "print(f'      num_heads={num_heads}, d_k(각 헤드 차원)={d_k}')\n",
        "print()\n",
        "\n",
        "# 입력 X\n",
        "X = np.random.randn(batch_size, seq_len, d_model)\n",
        "print(f'Step 1: 입력 X: {X.shape}')\n",
        "\n",
        "# W_Q로 Query 계산: (batch, seq, d_model) @ (d_model, d_model) = (batch, seq, d_model)\n",
        "W_Q = np.random.randn(d_model, d_model)\n",
        "Q = X @ W_Q  # (2, 5, 16)\n",
        "print(f'Step 2: Q = X @ W_Q: {Q.shape}')\n",
        "\n",
        "# Q를 헤드 수에 맞게 reshape\n",
        "# (batch, seq, d_model) → (batch, seq, num_heads, d_k) → (batch, num_heads, seq, d_k)\n",
        "Q_heads = Q.reshape(batch_size, seq_len, num_heads, d_k)\n",
        "print(f'Step 3: reshape Q: {Q.shape} → {Q_heads.shape}')\n",
        "\n",
        "Q_heads = Q_heads.transpose(0, 2, 1, 3)  # (batch, num_heads, seq, d_k)\n",
        "print(f'Step 4: transpose Q: → {Q_heads.shape}  (batch, num_heads, seq, d_k)')\n",
        "print('        이제 각 헤드가 독립적으로 seq×d_k 행렬을 처리!')\n",
        "print()\n",
        "\n",
        "# 각 헤드별 Attention 계산\n",
        "K_heads = (X @ np.random.randn(d_model, d_model)).reshape(batch_size, seq_len, num_heads, d_k).transpose(0, 2, 1, 3)\n",
        "V_heads = (X @ np.random.randn(d_model, d_model)).reshape(batch_size, seq_len, num_heads, d_k).transpose(0, 2, 1, 3)\n",
        "\n",
        "# 각 헤드: (batch, num_heads, seq, d_k) @ (batch, num_heads, d_k, seq) = (batch, num_heads, seq, seq)\n",
        "scores = Q_heads @ K_heads.transpose(0, 1, 3, 2) / np.sqrt(d_k)\n",
        "print(f'Step 5: Attention scores: {scores.shape}  (batch, heads, seq, seq)')\n",
        "\n",
        "# Softmax (마지막 차원에 대해)\n",
        "def softmax_last(x):\n",
        "    e_x = np.exp(x - x.max(axis=-1, keepdims=True))\n",
        "    return e_x / e_x.sum(axis=-1, keepdims=True)\n",
        "\n",
        "att_weights = softmax_last(scores)\n",
        "output_heads = att_weights @ V_heads  # (batch, heads, seq, d_k)\n",
        "print(f'Step 6: Attention output per head: {output_heads.shape}')\n",
        "\n",
        "# 헤드 합치기: (batch, heads, seq, d_k) → (batch, seq, heads, d_k) → (batch, seq, d_model)\n",
        "output = output_heads.transpose(0, 2, 1, 3)  # (batch, seq, heads, d_k)\n",
        "output = output.reshape(batch_size, seq_len, d_model)  # (batch, seq, d_model)\n",
        "print(f'Step 7: 헤드 concat 후: {output.shape}  (원래 shape 복원!)')\n",
        "\n",
        "print()\n",
        "print('▶ Multi-Head Attention은 Q,K,V를 헤드별로 나누고')\n",
        "print('  각각 Attention을 계산한 후 합치는 구조입니다!')"
      ]
    },
